# --- Converter service (Railway) ---
PBN_API_URL=https://your-service.up.railway.app
PBN_API_KEY=choose-a-long-random-string   # set the same value on Railway

# --- Vercel Blob (auto-added when you create a Blob store in the Vercel dashboard) ---
BLOB_READ_WRITE_TOKEN=

# --- Resend (resend.com -> API Keys) ---
RESEND_API_KEY=
EMAIL_FROM="Numbrush <hello@yourdomain.com>"  # must be a verified domain in Resend; onboarding@resend.dev works for testing
LEAD_NOTIFY_EMAIL=arnavmvn@gmail.com          # you get a ping for every lead

# --- Site ---
NEXT_PUBLIC_SITE_URL=https://your-site.vercel.app
